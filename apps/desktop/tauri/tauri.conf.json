{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Micracode",
  "version": "0.1.0",
  "identifier": "com.micracode.desktop.tauri",
  "build": {
    "beforeDevCommand": {
      "cwd": "../../web",
      "script": "bun run dev"
    },
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bash scripts/prepare-bundle.sh",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Micracode",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/backend/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
